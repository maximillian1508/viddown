# Viddown — copy to .env and edit for your machine
#   cp .env.example .env && chmod 600 .env

# --- Host paths / bind mounts ---
HOST_OUTPUT_DIR=/srv/apps/filebrowser-quantum/files/users/maxi1508/Downloads/videos
OUTPUT_DIR=/data/output
# Human-readable path shown in the UI (and in "Saved →" hints)

# --- Listen / publish ---
HOST_IP=127.0.0.1
HOST_PORT=8091
CONTAINER_PORT=8091
LISTEN_ADDR=:8091

# --- Process ---
PUID=1000
PGID=1000
TZ=Asia/Kuala_Lumpur
PROBE_TIMEOUT=45s
CHROME_PATH=/usr/bin/chromium
MEMORY_LIMIT=1536M
CONTAINER_NAME=viddown

# --- Traefik ---
TRAEFIK_HOST=viddown.maximillianleonard.dev
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=cf
TRAEFIK_NETWORK=proxy
