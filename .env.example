# Viddown — copy to .env and edit for your machine
#   cp .env.example .env && chmod 600 .env

# --- Host paths / bind mounts ---
HOST_OUTPUT_DIR=/path/to/Downloads/videos
OUTPUT_DIR=/data/output
# Human-readable path shown in the UI (and in "Saved →" hints)

# --- Listen / publish ---
HOST_IP=127.0.0.1
HOST_PORT=8091
CONTAINER_PORT=8091
LISTEN_ADDR=:8091

# --- Process ---
PUID=1000
PGID=1000
TZ=UTC
PROBE_TIMEOUT=45s
CHROME_PATH=/usr/bin/chromium
MAX_DOWNLOADS=10
MEMORY_LIMIT=1536M
CONTAINER_NAME=viddown

# Human path in UI ("Saved → …") — relative to your Filebrowser user root
OUTPUT_LABEL=Downloads/videos
# Full Filebrowser folder URL for "Open in Filebrowser" (filename appended)
FILEBROWSER_URL=https://files.example.com/files/My%20Files/Downloads/videos
# Optional: LibreTranslate on Docker network proxy (see /srv/apps/libretranslate)
LIBRETRANSLATE_URL=http://libretranslate:5000
TRANSLATE_TO=en

# --- Traefik ---
TRAEFIK_HOST=viddown.example.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_NETWORK=proxy
